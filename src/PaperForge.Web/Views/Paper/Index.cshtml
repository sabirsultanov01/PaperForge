@model List<Paper>
@{
    ViewData["Title"] = "My Papers";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-journal-text"></i> My Papers</h2>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> New Paper
        </a>
    </div>

    @if (Model.Count == 0)
    {
        <div class="text-center py-5">
            <i class="bi bi-journal-plus display-1 text-muted"></i>
            <h4 class="mt-3 text-muted">No papers yet</h4>
            <p class="text-muted">Create a new paper or import an existing document to get started.</p>
            <a asp-action="Create" class="btn btn-primary btn-lg mt-2">
                <i class="bi bi-plus-lg"></i> Create Your First Paper
            </a>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3">
            @foreach (var paper in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title">@paper.Title</h5>
                            @if (!string.IsNullOrEmpty(paper.Subject))
                            {
                                <p class="card-text text-muted small">@paper.Subject</p>
                            }
                            <div class="d-flex gap-2 mb-2">
                                <span class="badge bg-info">@paper.PaperType</span>
                                <span class="badge bg-secondary">@paper.CitationStyle</span>
                                <span class="badge bg-@(paper.Status switch {
                                    PaperStatus.Draft => "warning",
                                    PaperStatus.InProgress => "primary",
                                    PaperStatus.Review => "info",
                                    PaperStatus.Completed => "success",
                                    _ => "secondary"
                                })">@paper.Status</span>
                            </div>
                            <small class="text-muted">
                                @paper.Sections.Count section(s)
                                &middot; Updated @paper.UpdatedAt.ToString("MMM d, yyyy")
                            </small>
                            @if (paper.Deadline.HasValue)
                            {
                                <br />
                                <small class="text-danger">
                                    <i class="bi bi-clock"></i> Due @paper.Deadline.Value.ToString("MMM d, yyyy")
                                </small>
                            }
                        </div>
                        <div class="card-footer bg-transparent d-flex justify-content-between">
                            <a asp-action="Workspace" asp-route-id="@paper.Id" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i> Open
                            </a>
                            <form asp-action="Delete" asp-route-id="@paper.Id" method="post"
                                  onsubmit="return confirm('Delete this paper?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <div class="card mt-4">
        <div class="card-body">
            <h5><i class="bi bi-upload"></i> Import Existing Paper</h5>
            <p class="text-muted small">Upload a .docx, .pdf, or .txt file to continue working on it.</p>
            <form asp-controller="Import" asp-action="Upload" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <div class="row g-2 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label">File</label>
                        <input type="file" name="file" class="form-control" accept=".docx,.pdf,.txt" required />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Paper Title</label>
                        <input type="text" name="title" class="form-control" placeholder="My Research Paper" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Type</label>
                        <select name="paperType" class="form-select">
                            <option value="0">Academic Essay</option>
                            <option value="1">Literature Review</option>
                            <option value="2">Case Study</option>
                            <option value="3">Argumentative</option>
                            <option value="4">Scientific Report</option>
                            <option value="5">Comparative</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Citation Style</label>
                        <select name="citationStyle" class="form-select">
                            <option value="0">APA 7th</option>
                            <option value="1">MLA 9th</option>
                            <option value="2">Chicago 17th</option>
                        </select>
                    </div>
                    <div class="col-md-1">
                        <button type="submit" class="btn btn-primary w-100">Import</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
